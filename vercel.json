    { "source": "/kpi",             "destination": "/kpi.html"                  },
    { "source": "/api/weekly-report",    "destination": "/api/weekly-report.js"    },
    { "source": "/api/update-dashboard", "destination": "/api/update-dashboard.js" }
  ]
}
